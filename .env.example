# Expo / app runtime configuration
# Set APP_ENV to development, staging, or production.
APP_ENV=development

# App service endpoints
TRYON_BASE_URL_DEVELOPMENT=http://192.168.1.10:8787
TRYON_BASE_URL_STAGING=
TRYON_BASE_URL_PRODUCTION=
RECOMMENDER_BASE_URL_DEVELOPMENT=${TRYON_BASE_URL_DEVELOPMENT}
RECOMMENDER_BASE_URL_STAGING=
RECOMMENDER_BASE_URL_PRODUCTION=
EXPO_PUBLIC_STRIPE_BACKEND_URL_DEVELOPMENT=http://192.168.1.10:4242
EXPO_PUBLIC_STRIPE_BACKEND_URL_STAGING=
EXPO_PUBLIC_STRIPE_BACKEND_URL_PRODUCTION=

# Public Stripe key
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY_DEVELOPMENT=pk_test_replace_me
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY_STAGING=pk_test_replace_me
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY_PRODUCTION=pk_live_replace_me

# Public Firebase web config
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# OAuth / public frontend config
