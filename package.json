{
  "name": "fshn",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "check:server": "npm --prefix server run check",
    "test:server:integration": "npm --prefix server run test:integration",
    "check:functions": "npm --prefix functions run check",
    "check:tryon": "npm --prefix tryon-local run check",
    "check:config": "npm --prefix server run validate:config && npm --prefix tryon-local run validate:config",
    "check:rules": "npm --prefix \"Testing py/fb auto testing py\" run test:rules",
    "ci:required": "npm run typecheck && npm run check:server && npm run check:functions && npm run check:tryon && npm run check:config"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@google-cloud/vertexai": "^1.10.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@stripe/stripe-react-native": "^0.57.2",
    "expo": "~54.0.25",
    "expo-asset": "^12.0.10",
    "expo-blur": "~15.0.7",
    "expo-camera": "~17.0.9",
    "expo-clipboard": "~8.0.7",
    "expo-constants": "~18.0.10",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.19",
    "expo-font": "~14.0.9",
    "expo-haptics": "~15.0.7",
    "expo-image": "~3.0.10",
    "expo-image-manipulator": "~14.0.7",
    "expo-image-picker": "~17.0.8",
    "expo-linear-gradient": "~15.0.7",
    "expo-media-library": "~18.2.0",
    "expo-status-bar": "~3.0.8",
    "expo-web-browser": "~15.0.9",
    "firebase": "^12.8.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "overrides": {
    "react-native-worklets": "0.5.1"
  }
