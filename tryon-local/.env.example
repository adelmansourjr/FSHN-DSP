APP_ENV=development

# REQUIRED
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
VIRTUAL_TRYON_MODEL=virtual-try-on-preview-08-04
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# SERVER
PORT=8787
TRYON_DEBUG=1
ALLOW_GUEST_AI_ROUTES=0
TRYON_PERSON_MAX_LONG=1152
TRYON_PRODUCT_MAX_LONG=1024
TRYON_INPUT_PIXEL_LIMIT=80000000
TRYON_JOB_TTL_MS=1800000
TRYON_JOB_SWEEP_INTERVAL_MS=300000

# Recommender / classifier v2
RECOMMENDER_PROJECT=your-project-id
RECOMMENDER_LOCATION=global
RECOMMENDER_MODEL=gemini-2.5-flash
RECOMMENDER_EMBEDDING_MODEL=gemini-embedding-001
RECOMMENDER_PARSER_MODE=auto
RECOMMENDER_EMBEDDING_MODE=hybrid
RECOMMENDER_GEMINI_TIMEOUT_MS=20000
RECOMMENDER_POOL_SIZE=5
RECOMMENDER_PER_ROLE_LIMIT=18
RECOMMENDER_EPSILON=0.08
RECOMMENDER_JITTER=0.03
RECOMMENDER_LIVE_REFRESH_TTL_MS=600000
RECOMMENDER_TIMING_LOGS=0
RECOMMENDER_DURABLE_PROMPT_CACHE=0
RECOMMENDER_DURABLE_PAIRWISE_CACHE=1
CLASSIFIER_MIN_COLOURS=1
INGEST_API_KEY=replace-with-internal-key
FARFETCH_IMAGE_URL_TEMPLATE=
FARFETCH_IMAGE_BASE_URL=

# Optional: server-side Google Custom Search for Vision web similarity results
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
VISION_WEB_DEFAULT_NUM=8
VISION_WEB_MAX_NUM=10

# Optional CORS allowlist for web builds (comma-separated origins)
# CORS_ORIGINS=https://your-moda-domain.com,https://another-allowed-origin.com

# Firebase Admin credentials for local / Cloud Run
# GOOGLE_APPLICATION_CREDENTIALS=/Users/<you>/keys/tryon-local.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
