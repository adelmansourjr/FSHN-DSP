APP_ENV=development
PORT=4242

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Firebase Admin
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_SERVICE_ACCOUNT_JSON=
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Public base URL for Stripe success/cancel redirects
# Example: https://app.example.com
PUBLIC_BASE_URL=http://localhost:4242

# Fixed ShippingCo shipping fees (GBP)
ROYAL_MAIL_FIXED_FEE_SMALL_GARMENT_GBP=4.99
ROYAL_MAIL_FIXED_FEE_BULKY_GARMENT_GBP=6.99
ROYAL_MAIL_FIXED_FEE_SHOEBOX_GBP=7.99

# Sandbox tracking timings
ROYAL_MAIL_SANDBOX_IN_TRANSIT_SEC=20
ROYAL_MAIL_SANDBOX_OUT_FOR_DELIVERY_SEC=40
ROYAL_MAIL_SANDBOX_DELIVERED_SEC=60
